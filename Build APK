name: Build APK

on:
  workflow_dispatch:
  push:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Unzip project
        run: unzip -o StationAlarm.zip -d .

      - name: Insert Maps API key
        run: |
          sed -i "s/YOUR_GOOGLE_MAPS_API_KEY_HERE/${{ secrets.MAPS_API_KEY }}/g" StationAlarm/app/src/main/AndroidManifest.xml

      - name: Fix repository configuration conflict
        run: |
          sed -i '/^allprojects {/,/^}/d' StationAlarm/build.gradle
          cat StationAlarm/build.gradle

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '17'

      - name: Set up Gradle
        uses: gradle/actions/setup-gradle@v3
        with:
          gradle-version: '8.5'

      - name: Build debug APK
        working-directory: ./StationAlarm
        run: gradle assembleDebug

      - name: Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: StationAlarm-debug-apk
          path: StationAlarm/app/build/outputs/apk/debug/app-debug.apk
